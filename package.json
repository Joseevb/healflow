{
  "name": "healflow",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "bunx --bun auth@latest generate -y --output=src/db/schemas/auth.ts --config=src/lib/auth.ts",
    "build": "bunx --bun vite build",
    "check": "oxfmt && oxlint --fix",
    "cn:add": "bunx --bun shadcn@latest add",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:push": "bunx --bun drizzle-kit push",
    "dev": "bunx --bun vite dev --port 3000",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preview": "bunx --bun vite preview",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "test": "bun test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/stripe": "^1.6.9",
    "@faker-js/faker": "^10.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@react-email/render": "^2.0.8",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "5.100.8",
    "@tanstack/react-query-devtools": "5.100.8",
    "@tanstack/react-router": "1.169.1",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "1.166.12",
    "@tanstack/react-start": "1.167.59",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.167.32",
    "@typescript/native-preview": "^7.0.0-dev.20260502.1",
    "@unpic/react": "^1.0.2",
    "better-auth": "^1.6.9",
    "better-result": "^2.9.1",
    "bun": "^1.3.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260501-164602-aee73f19",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.12.2",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "portless": "^0.12.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "portless": {
    "name": "healflow",
    "script": "dev"
  }
}
