{
  "name": "healflow",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "bunx --bun auth@latest generate -y --output=src/db/schemas/auth.ts --config=src/lib/auth.ts",
    "build": "bunx --bun vite build",
    "check": "oxfmt && oxlint --fix",
    "cn:add": "bunx --bun shadcn@latest add",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bun run ./src/db/migrate.ts",
    "db:push": "bunx --bun drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts admin && bun run src/db/seed.ts specialists && bun run src/db/seed.ts basic-specialist",
    "dev": "bunx --bun vite dev --port 3000",
    "dev:debug": "bun --inspect=9229 vite dev --port 3000",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prebuild": "bun db:generate && bun db:migrate && bun db:seed",
    "preview": "bunx --bun vite preview",
    "start": "bun .output/server/index.mjs",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "test": "bun test",
    "tsc": "tsgo",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@base-ui/react": "^1.5.0",
    "@better-auth/stripe": "^1.6.11",
    "@faker-js/faker": "^10.3.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@react-email/render": "^2.0.8",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-form": "1.32.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.13",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.168.11",
    "@typescript/native-preview": "^7.0.0-dev.20260526.1",
    "@unpic/react": "^1.0.2",
    "better-auth": "^1.6.11",
    "better-result": "^2.9.2",
    "bun": "^1.3.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "effect": "^3.21.2",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "nitro": "npm:nitro-nightly@3.0.260522-beta",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/vite-plugin": "^0.3.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "portless": "^0.12.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "portless": {
    "name": "healflow",
    "script": "dev"
  }
}
